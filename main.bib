	note = {Place: 445 HOES LANE, PISCATAWAY, NJ 08855-4141 USA
Type: Article},
	keywords = {Quantum computing, Anomaly detection, Fraud, Real-time systems, Credit cards, Computational modeling, credit card fraud detection, Integrated circuit modeling, Noise, Computational efficiency, imbalanced dataset, quantum autoencoder (QAE), quantum machine learning (QML), Quantum state},
	pages = {169671--169682},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/ACVDH6GY/Huot et al. - 2024 - Quantum Autoencoder for Enhanced Fraud Detection in Imbalanced Credit Card Dataset.pdf:application/pdf},
