Type: Article},
	keywords = {Finance, Artificial neural networks, Fraud, machine learning, Accuracy, Companies, Computational modeling, Support vector machines, Analytical models, fraud detection, Logistic regression, Random forests, feature selection, Financial statement fraud},
	pages = {194859--194870},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/KZCTPJWX/Li et al. - 2024 - Uncovering Financial Statement Fraud A Machine Learning Approach With Key Financial Indicators and.pdf:application/pdf},
