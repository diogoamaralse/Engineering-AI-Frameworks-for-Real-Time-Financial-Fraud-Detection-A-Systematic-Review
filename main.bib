	pages = {83762--83785},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/4L6PTN9C/Chen et al. - 2021 - Variational Autoencoders and Wasserstein Generative Adversarial Networks for Improving the Anti-Mone.pdf:application/pdf},
