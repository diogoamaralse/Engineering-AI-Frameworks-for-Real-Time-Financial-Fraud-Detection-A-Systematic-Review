	file = {Full Text PDF:/Users/damaral/Zotero/storage/LNPBUQT7/Breskuviene and Dzemyda - 2023 - Categorical Feature Encoding Techniques for Improved Classifier Performance when Dealing with Imbala.pdf:application/pdf},
