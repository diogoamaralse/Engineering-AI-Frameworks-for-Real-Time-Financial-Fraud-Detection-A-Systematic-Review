	note = {Place: RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS
Type: Article},
	keywords = {ADASYN, K-Means SMOTE, LGBM, SMOTENC},
	file = {PDF:/Users/damaral/Zotero/storage/QVPF2A53/Ravindranath et al. - 2024 - Evaluation of performance enhancement in Ethereum fraud detection using oversampling techniques.pdf:application/pdf},
