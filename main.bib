	keywords = {detection, Fraud, Feature extraction, Data models, Convolutional neural networks, Credit cards, Accuracy, Long short term memory, convolutional neural networks, Classification tree analysis, Data preprocessing, credit card fraud, Attention mechanisms, Attention, long-short term memory},
	pages = {114056--114068},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/9ZYT3BT3/Akour et al. - 2025 - Hybrid CNN-LSTM With Attention Mechanism for Robust Credit Card Fraud Detection.pdf:application/pdf},
