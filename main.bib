Type: Article},
	keywords = {Fraud, Class imbalance, Classification algorithms, Training, fraud detection, Self-supervised learning, Heuristic algorithms, graph neural network (GNN), heterogeneous graph, Image edge detection, inductive node classification},
	pages = {4904--4915},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/PKBZX9EI/Van Belle and De Weerdt - 2024 - SHINE A Scalable Heterogeneous Inductive Graph Neural Network for Large Imbalanced Datasets.pdf:application/pdf},
