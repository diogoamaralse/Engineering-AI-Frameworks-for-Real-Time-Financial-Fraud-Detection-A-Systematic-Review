Type: Article},
	keywords = {Fraud, Credit card fraud detection, Feature extraction, Data models, Predictive models, Credit cards, Task analysis, feature boosting, multifactor embedding, oversampling technique, Redundancy},
	pages = {1615--1630},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/D6J57FKH/Ni et al. - 2024 - Fraud Feature Boosting Mechanism and Spiral Oversampling Balancing Technique for Credit Card Fraud D.pdf:application/pdf},
