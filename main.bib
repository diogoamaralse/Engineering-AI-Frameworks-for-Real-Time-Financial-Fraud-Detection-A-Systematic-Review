Type: Article},
	keywords = {Machine learning, Random undersampling, Credit Card Fraud Detection Dataset, Output thresholding},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/XZX9NPD8/Leevy et al. - 2023 - Threshold optimization and random undersampling for imbalanced credit card data.pdf:application/pdf},
}

