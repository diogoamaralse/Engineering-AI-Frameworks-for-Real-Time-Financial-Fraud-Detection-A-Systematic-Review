Type: Article},
	keywords = {Deep learning, Machine learning, Credit card fraud detection, Feature selection, Iterative weighted feature selection (IWFS), Recurrent neural network},
	pages = {615--638},
	file = {Full Text PDF:/Users/damaral/Zotero/storage/YYVEU5AB/Sobana et al. - 2025 - A Sophisticated Iterative Weighted Feature Selection (IWFS) Based Spiking Imperialist Competitive Re.pdf:application/pdf},
