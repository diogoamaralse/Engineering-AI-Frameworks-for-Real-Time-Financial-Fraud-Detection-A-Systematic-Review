	note = {Place: THE BOULEVARD, LANGFORD LANE, KIDLINGTON, OXFORD OX5 1GB, ENGLAND
Type: Article},
	keywords = {Cybersecurity, Unsupervised learning, Machine learning, Fraud detection, Explainable AI, Bank trasactions},
	file = {PDF:/Users/damaral/Zotero/storage/KD4TJFZ4/Karnavou et al. - 2025 - I know you're a fraud Uncovering illicit activity in a Greek bank transactions with unsupervised le.pdf:application/pdf},
